{
  "name": "@symbiosis-finance/tracing",
  "version": "2.0.0",
  "exports": { ".": "./src/index.ts" },
  "publish": {
    "exclude": ["node_modules/", "src/**/*.test.ts", "src/__snapshots__/", ".claude/", ".github/"]
  },
  "nodeModulesDir": "auto",
  "permissions": {
    "test": {
      "net": true,
      "read": true,
      "write": true,
      "env": true,
      "sys": true
    }
  },
  "tasks": {
    "test": "deno test -P=test src/",
    "lint": "deno fmt --check src/ && deno lint src/ && deno check src/",
    "fmt": "deno fmt src/"
  },
  "fmt": {
    "include": ["src/"],
    "semiColons": false,
    "singleQuote": true,
    "indentWidth": 4,
    "lineWidth": 120,
    "sortNamedImports": false
  },
  "lint": {
    "include": ["src/"]
  },
  "imports": {
    "@logtape/logtape": "npm:@logtape/logtape@^1.3.6",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "npm:@opentelemetry/exporter-trace-otlp-http@^0.211.0",
    "@opentelemetry/instrumentation": "npm:@opentelemetry/instrumentation@^0.211.0",
    "@opentelemetry/instrumentation-undici": "npm:@opentelemetry/instrumentation-undici@^0.21.0",
    "@opentelemetry/resource-detector-container": "npm:@opentelemetry/resource-detector-container@^0.8.2",
    "@opentelemetry/resource-detector-gcp": "npm:@opentelemetry/resource-detector-gcp@^0.46.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^2.5.0",
    "@opentelemetry/sdk-trace-node": "npm:@opentelemetry/sdk-trace-node@^2.5.0",
    "@opentelemetry/semantic-conventions": "npm:@opentelemetry/semantic-conventions@^1.39.0",
    "@std/testing": "jsr:@std/testing@^1.0.18",
    "zod": "npm:zod@^4.3.5"
  }
}
